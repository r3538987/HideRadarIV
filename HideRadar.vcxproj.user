<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release GTA4|Win32'">
    <LocalDebuggerCommand>$(GTA_IV_DIR)\GTAIV.exe</LocalDebuggerCommand>
    <LocalDebuggerWorkingDirectory>$(GTA_IV_DIR)</LocalDebuggerWorkingDirectory>
    <DebuggerFlavor>WindowsLocalDebugger</DebuggerFlavor>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug GTA4|Win32'">
    <LocalDebuggerCommand>$(GTA_IV_DIR)\GTAIV.exe</LocalDebuggerCommand>
    <LocalDebuggerWorkingDirectory>$(GTA_IV_DIR)</LocalDebuggerWorkingDirectory>
    <DebuggerFlavor>WindowsLocalDebugger</DebuggerFlavor>
  </PropertyGroup>
</Project>